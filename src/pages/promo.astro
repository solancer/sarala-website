---
// Self-running, looping marketing reel for Sarala.
// Standalone (not wrapped in the site Layout) and noindex — built to be
// screen-recorded or embedded. Add ?vertical for a 9:16 (Reels/Shorts) frame,
// ?clean to hide the on-screen HUD.
import "../styles/global.css";
---

<!doctype html>
<html lang="en" data-theme="pro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Sarala — promo reel</title>
    <link rel="icon" type="image/png" href="/assets/sarala-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      html, body { height: 100%; overflow: hidden; }
      body { display: grid; place-items: center; background: var(--bg-deep); }

      /* The recording stage. Record THIS element for a clean clip. */
      .reel {
        position: relative;
        width: min(1120px, 94vw);
        aspect-ratio: 16 / 9;
        background: var(--bg);
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 50px 120px -50px rgba(0,0,0,.8), 0 0 0 1px var(--border);
        transition: background-color .6s cubic-bezier(.4,0,.2,1);
      }
      .reel.vertical { width: min(420px, 94vw); aspect-ratio: 9 / 16; }

      /* ambient backdrop */
      .reel-grid {
        position: absolute; inset: 0; pointer-events: none; opacity: .3;
        background-image:
          linear-gradient(var(--border) 1px, transparent 1px),
          linear-gradient(90deg, var(--border) 1px, transparent 1px);
        background-size: 42px 42px;
        -webkit-mask-image: radial-gradient(ellipse 75% 65% at 50% 40%, #000 10%, transparent 75%);
                mask-image: radial-gradient(ellipse 75% 65% at 50% 40%, #000 10%, transparent 75%);
      }
      .reel-glow {
        position: absolute; width: 70%; height: 70%; border-radius: 50%;
        filter: blur(110px); opacity: .2; top: -25%; left: 50%; transform: translateX(-50%);
        background: radial-gradient(circle, var(--purple), transparent 65%);
        pointer-events: none;
      }

      /* scenes */
      .scene {
        position: absolute; inset: 0; z-index: 2;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        gap: 14px; padding: clamp(22px, 4vw, 52px); text-align: center;
        opacity: 0; transform: translateY(14px) scale(.992);
        transition: opacity .55s ease, transform .55s cubic-bezier(.2,.7,.2,1);
      }
      .scene.show { opacity: 1; transform: none; }

      /* progress bar */
      .reel-bar {
        position: absolute; left: 0; bottom: 0; height: 4px; width: 0; z-index: 5;
        background: linear-gradient(90deg, var(--red), var(--orange) 20%, var(--yellow) 40%, var(--green) 60%, var(--blue) 80%, var(--purple));
      }

      /* --- intro scene --- */
      .intro-mark { width: clamp(78px, 12vw, 120px); height: auto; border-radius: 22px; filter: drop-shadow(0 18px 40px rgba(0,0,0,.5)); }
      [data-theme="paper"] .intro-mark { box-shadow: 0 10px 30px -8px rgba(0,0,0,.3); }
      .intro-word { font-size: clamp(44px, 8vw, 92px); font-weight: 600; letter-spacing: -.04em; line-height: 1; margin-top: 6px; }
      .intro-tag { font-size: clamp(16px, 2.4vw, 24px); color: var(--muted); max-width: 22ch; line-height: 1.3; }
      .intro-pill {
        margin-top: 6px; font-family: "JetBrains Mono", monospace; font-size: clamp(11px, 1.5vw, 14px);
        color: var(--muted); border: 1px solid var(--border); background: var(--bg-panel);
        padding: 6px 14px; border-radius: 100px;
      }
      .intro-pill b { color: var(--fg); }
      .grad {
        background: linear-gradient(105deg, var(--red), var(--orange) 30%, var(--yellow) 55%, var(--green) 78%, var(--blue));
        -webkit-background-clip: text; background-clip: text; color: transparent;
      }

      /* --- editor scene --- */
      .editor-scene { padding: clamp(22px, 4vw, 46px); }
      .reel .window { width: 100%; max-width: 820px; }
      .reel .win-body { grid-template-columns: 178px 1fr; min-height: 0; }
      .reel.vertical .win-body { grid-template-columns: 1fr; }
      .reel.vertical .sidebar { display: none; }
      .reel .editor { min-height: 0; padding: 26px clamp(20px, 3vw, 38px); font-size: 15px; }
      .reel .doc h1 { font-size: 25px; }
      .reel .doc h2 { font-size: 18px; margin-top: 18px; }
      .reel .codeblock { font-size: 12.5px; }
      .palette-chip {
        position: absolute; top: 16px; right: 18px; z-index: 4;
        display: inline-flex; align-items: center; gap: 9px;
        font-family: "JetBrains Mono", monospace; font-size: 12.5px; color: var(--muted);
        background: var(--bg-panel); border: 1px solid var(--border);
        padding: 7px 13px; border-radius: 100px; opacity: 0; transition: opacity .4s;
      }
      .palette-chip.on { opacity: 1; }
      .palette-chip b { color: var(--fg); text-transform: capitalize; }
      .palette-chip .swatch { width: 11px; height: 11px; border-radius: 50%; background: var(--red); }

      /* --- features scene --- */
      .feat-head { font-size: clamp(24px, 3.6vw, 40px); font-weight: 600; letter-spacing: -.03em; margin-bottom: 8px; }
      .feat-row { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; max-width: 860px; }
      .reel.vertical .feat-row { flex-direction: column; align-items: stretch; }
      .feat-tile {
        flex: 1 1 200px; min-width: 180px;
        background: var(--bg-panel); border: 1px solid var(--border); border-radius: 14px;
        padding: 20px; text-align: left;
        opacity: 0; transform: translateY(18px);
        transition: opacity .5s cubic-bezier(.2,.7,.2,1), transform .5s cubic-bezier(.2,.7,.2,1);
      }
      .feat-tile.in { opacity: 1; transform: none; }
      .feat-tile h4 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
      .feat-tile p { color: var(--muted); font-size: 13.5px; line-height: 1.45; }
      .feat-tile .math-mini, .feat-tile .diagram { margin-top: 12px; }
      .feat-tile .pills { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; }

      /* --- outro scene --- */
      .outro-h { font-size: clamp(30px, 5.6vw, 60px); font-weight: 600; letter-spacing: -.035em; line-height: 1.04; }
      .outro-url {
        font-family: "JetBrains Mono", monospace; font-size: clamp(16px, 2.4vw, 24px);
        color: var(--green); margin-top: 4px;
      }
      .outro-row { display: flex; gap: 12px; align-items: center; margin-top: 12px; flex-wrap: wrap; justify-content: center; }
      .outro-btn { background: var(--green); color: var(--bg-deep); font-weight: 600; font-size: 15px; padding: 12px 22px; border-radius: 11px; display: inline-flex; gap: 9px; align-items: center; }
      .outro-btn svg { width: 17px; height: 17px; }
      .os-pills { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-top: 6px; font-family: "JetBrains Mono", monospace; font-size: 12px; color: var(--muted); }
      .os-pills span { border: 1px solid var(--border); border-radius: 100px; padding: 4px 11px; }

      /* HUD (hidden with ?clean, auto-fades) */
      .hud {
        position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
        font-family: "JetBrains Mono", monospace; font-size: 12px; color: var(--faint);
        background: color-mix(in srgb, var(--bg-panel) 80%, transparent);
        border: 1px solid var(--border); padding: 7px 14px; border-radius: 100px;
        transition: opacity .6s; z-index: 50; white-space: nowrap;
      }
      .hud.gone { opacity: 0; pointer-events: none; }

      @media (prefers-reduced-motion: reduce) {
        .scene { transition: none; }
      }
    </style>
  </head>
  <body>
    <div class="reel" id="reel">
      <div class="reel-grid"></div>
      <div class="reel-glow"></div>

      <!-- 1 · INTRO -->
      <div class="scene" data-scene="intro">
        <img class="intro-mark" src="/assets/sarala-icon.png" alt="Sarala" />
        <div class="intro-word">Sarala</div>
        <div class="intro-tag">Markdown that reads like a <span class="grad">finished document.</span></div>
        <div class="intro-pill"><b>v2.0</b> · free &amp; open source · GPL-3.0</div>
      </div>

      <!-- 2 · EDITOR (typing + theme cycle) -->
      <div class="scene editor-scene" data-scene="editor">
        <div class="palette-chip" id="palette-chip"><span class="swatch"></span>palette · <b id="palette-name">Pro</b></div>
        <div class="window">
          <div class="win-bar">
            <span class="lights"><i></i><i></i><i></i></span>
            <span class="win-title"><span class="dot-unsaved"></span> welcome.md</span>
            <span class="win-tabs"><span class="win-tab active">Live</span><span class="win-tab">Source</span></span>
          </div>
          <div class="win-body">
            <aside class="sidebar">
              <div class="sb-group-label">Workspace</div>
              <div class="sb-item active"><svg class="fic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2h9l5 5v15H6z"></path><path d="M15 2v5h5"></path></svg> welcome.md</div>
              <div class="sb-item"><svg class="fic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2h9l5 5v15H6z"></path><path d="M15 2v5h5"></path></svg> essay.md</div>
              <div class="sb-group-label" style="margin-top:14px">Outline</div>
              <div class="sb-item" style="color:var(--green)">› Sarala</div>
              <div class="sb-item" style="padding-left:24px">› Why writers love it</div>
            </aside>
            <div class="editor doc" id="reel-editor">
              <h1 data-block data-segs='[{"t":"# ","c":"mk"},{"t":"Sarala","c":""}]'></h1>
              <p data-block data-segs='[{"t":"A Markdown editor that ","c":""},{"t":"**","c":"mk"},{"t":"renders","c":"tb"},{"t":"**","c":"mk"},{"t":" as you ","c":""},{"t":"_","c":"mk"},{"t":"type","c":"ti"},{"t":"_","c":"mk"},{"t":".","c":""}]'></p>
              <h2 data-block data-segs='[{"t":"## ","c":"mk"},{"t":"Why writers love it","c":""}]'></h2>
              <ul>
                <li class="task" data-block data-segs='[{"t":"- [x] ","c":"box"},{"t":"No preview pane, no split view","c":""}]'></li>
                <li class="task" data-block data-segs='[{"t":"- [x] ","c":"box"},{"t":"Live math, diagrams &amp; ","c":""},{"t":"`","c":"mk"},{"t":"code","c":"tc"},{"t":"`","c":"mk"}]'></li>
                <li class="task" data-block data-segs='[{"t":"- [ ] ","c":"box-todo"},{"t":"Export anywhere","c":""}]'></li>
              </ul>
              <blockquote data-block data-segs='[{"t":"> ","c":"mk"},{"t":"Plain text in. Finished document out.","c":""}]'></blockquote>
            </div>
          </div>
        </div>
      </div>

      <!-- 3 · FEATURES -->
      <div class="scene" data-scene="features">
        <div class="feat-head">One file. <span class="grad">Every kind of content.</span></div>
        <div class="feat-row">
          <div class="feat-tile" data-i="0">
            <h4>Math &amp; equations</h4>
            <p>Inline &amp; block LaTeX, rendered live with KaTeX.</p>
            <div class="math-mini">e<sup>iπ</sup> + 1 = 0&nbsp;&nbsp;·&nbsp;&nbsp;<span class="frac"><span>a</span><span>b</span></span></div>
          </div>
          <div class="feat-tile" data-i="1">
            <h4>Diagrams</h4>
            <p>Flowcharts &amp; sequences from Mermaid blocks.</p>
            <div class="diagram"><span class="dnode a">idea</span><span class="darrow">→</span><span class="dnode b">draft</span><span class="darrow">→</span><span class="dnode c">ship</span></div>
          </div>
          <div class="feat-tile" data-i="2">
            <h4>Export anywhere</h4>
            <p>One document, every format — no lock-in.</p>
            <div class="pills">
              <span class="dnode" style="color:var(--red)">PDF</span>
              <span class="dnode" style="color:var(--orange)">HTML</span>
              <span class="dnode" style="color:var(--yellow)">.docx</span>
              <span class="dnode" style="color:var(--green)">LaTeX</span>
              <span class="dnode" style="color:var(--blue)">EPUB</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 4 · OUTRO -->
      <div class="scene" data-scene="outro">
        <img class="intro-mark" src="/assets/sarala-icon.png" alt="Sarala" style="width:clamp(56px,8vw,84px)" />
        <div class="outro-h">Stop previewing.<br /><span class="grad">Start writing.</span></div>
        <div class="outro-url">sarala.solancer.com</div>
        <div class="outro-row">
          <span class="outro-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"></path><path d="m7 11 5 5 5-5"></path><path d="M5 21h14"></path></svg>
            Download free
          </span>
        </div>
        <div class="os-pills"><span>macOS</span><span>Windows</span><span>Linux</span><span>GPL-3.0</span></div>
      </div>

      <div class="reel-bar" id="reel-bar"></div>
    </div>

    <div class="hud" id="hud">▶ auto-looping · press R to restart · add ?vertical for 9:16 · ?clean to hide this</div>

    <script>
      (function () {
        "use strict";
        const params = new URLSearchParams(location.search);
        const reel = document.getElementById("reel");
        if (params.has("vertical")) reel.classList.add("vertical");

        const hud = document.getElementById("hud");
        if (params.has("clean")) { hud.remove(); }
        else { setTimeout(() => hud.classList.add("gone"), 4200); }

        const THEMES = [
          { id: "pro", name: "Pro" },
          { id: "octagon", name: "Octagon" },
          { id: "machine", name: "Machine" },
          { id: "ristretto", name: "Ristretto" },
          { id: "spectrum", name: "Spectrum" },
          { id: "classic", name: "Classic" },
          { id: "paper", name: "Paper" },
        ];

        const scenes = {};
        document.querySelectorAll(".scene").forEach((s) => (scenes[s.dataset.scene] = s));

        const sleep = (ms) => new Promise((r) => setTimeout(r, ms));
        const setTheme = (id) => document.documentElement.setAttribute("data-theme", id);
        const show = (el) => el.classList.add("show");
        const hide = (el) => el.classList.remove("show");

        /* ---- typing engine (matches the site's segment renderer) ---- */
        function escapeHtml(s) {
          return s.replace(/&amp;/g, "&").replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
        }
        function renderSegs(segs, n) {
          let out = "", count = 0;
          for (const s of segs) {
            let txt = s.t;
            if (n !== undefined) {
              if (count >= n) break;
              const take = Math.min(txt.length, n - count);
              txt = txt.slice(0, take);
              count += take;
            }
            const open = s.c ? '<span class="' + s.c + '">' : "";
            const close = s.c ? "</span>" : "";
            out += open + escapeHtml(txt) + close;
            if (n !== undefined && count >= n) break;
          }
          return out;
        }

        const editor = document.getElementById("reel-editor");
        const blocks = Array.prototype.slice.call(editor.querySelectorAll("[data-block]"));
        const blockData = blocks.map((b) => JSON.parse(b.getAttribute("data-segs")));
        const blockLen = blockData.map((segs) => segs.reduce((a, s) => a + s.t.length, 0));

        const caret = document.createElement("span");
        caret.className = "caret";

        function resetEditor() {
          blocks.forEach((b) => { b.innerHTML = ""; b.style.opacity = "0"; });
        }
        function typeBlock(i) {
          return new Promise((resolve) => {
            const b = blocks[i], segs = blockData[i], total = blockLen[i];
            b.style.opacity = "1";
            let n = 0;
            (function tick() {
              n++;
              b.innerHTML = renderSegs(segs, n);
              b.appendChild(caret);
              if (n < total) setTimeout(tick, 15 + Math.random() * 20);
              else { setTimeout(resolve, 140); }
            })();
          });
        }

        /* ---- palette chip ---- */
        const chip = document.getElementById("palette-chip");
        const chipName = document.getElementById("palette-name");

        /* ---- features stagger ---- */
        const tiles = Array.prototype.slice.call(scenes.features.querySelectorAll(".feat-tile"));
        function resetTiles() { tiles.forEach((t) => t.classList.remove("in")); }

        /* ---- progress bar (continuous per loop) ---- */
        const bar = document.getElementById("reel-bar");
        const LOOP_MS = 27000; // approximate; bar is decorative
        let loopStart = 0;
        (function barTick() {
          const t = performance.now() - loopStart;
          bar.style.width = Math.max(0, Math.min(100, (t / LOOP_MS) * 100)) + "%";
          requestAnimationFrame(barTick);
        })();

        let runToken = 0;
        async function run() {
          const token = ++runToken;
          const alive = () => token === runToken;

          while (alive()) {
            loopStart = performance.now();

            // reset everything
            Object.values(scenes).forEach(hide);
            setTheme("pro");
            resetEditor();
            resetTiles();
            chip.classList.remove("on");
            await sleep(120);

            // 1 · intro
            show(scenes.intro);
            await sleep(3000);
            hide(scenes.intro);
            await sleep(560);
            if (!alive()) return;

            // 2 · editor: type, then cycle palettes
            show(scenes.editor);
            await sleep(450);
            for (let i = 0; i < blocks.length; i++) {
              if (!alive()) return;
              await typeBlock(i);
            }
            if (caret.parentNode) caret.parentNode.removeChild(caret);
            await sleep(650);
            // cycle palettes live
            chip.classList.add("on");
            for (let t = 0; t < THEMES.length; t++) {
              if (!alive()) return;
              setTheme(THEMES[t].id);
              chipName.textContent = THEMES[t].name;
              await sleep(820);
            }
            await sleep(350);
            chip.classList.remove("on");
            hide(scenes.editor);
            await sleep(560);
            if (!alive()) return;

            // 3 · features
            setTheme("pro");
            show(scenes.features);
            await sleep(300);
            for (let i = 0; i < tiles.length; i++) {
              tiles[i].classList.add("in");
              await sleep(420);
            }
            await sleep(2600);
            hide(scenes.features);
            await sleep(560);
            if (!alive()) return;

            // 4 · outro
            show(scenes.outro);
            await sleep(4000);
            hide(scenes.outro);
            await sleep(620);
          }
        }

        // restart on R
        addEventListener("keydown", (e) => { if (e.key === "r" || e.key === "R") run(); });

        run();
      })();
    </script>
  </body>
</html>
