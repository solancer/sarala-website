---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  /** Page-relative path, e.g. "/" — used for canonical + og:url */
  path?: string;
  ogImage?: string;
}

const {
  title = "Sarala — A Markdown editor that gets out of your way",
  description = "Sarala is a free, open-source WYSIWYG Markdown editor that renders as you type — no preview pane, no split view. Live math, diagrams, syntax highlighting, and export to PDF, HTML, and more. For macOS, Windows & Linux.",
  path = "/",
  ogImage = "/screenshots/hero-final.png",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://sarala.solancer.com");
const canonical = new URL(path, siteUrl).href;
const ogImageAbs = new URL(ogImage, siteUrl).href;
const GITHUB = "https://github.com/solancer/sarala";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Sarala",
  applicationCategory: "DeveloperApplication",
  applicationSubCategory: "Markdown Editor",
  operatingSystem: "macOS, Windows, Linux",
  description,
  url: siteUrl.href,
  downloadUrl: `${GITHUB}/releases`,
  license: "https://www.gnu.org/licenses/gpl-3.0.html",
  isAccessibleForFree: true,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  softwareVersion: "2.0",
  author: {
    "@type": "Person",
    name: "Srinivas Gowda",
    url: "https://github.com/solancer",
  },
};
---

<!doctype html>
<html lang="en" data-theme="pro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#221f22" />
    <meta name="color-scheme" content="dark light" />

    <!-- Icons -->
    <link rel="icon" type="image/png" href="/assets/sarala-icon.png" />
    <link rel="apple-touch-icon" href="/assets/sarala-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sarala" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="909" />
    <meta property="og:image:height" content="540" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Theme is restored before paint to avoid a flash of the default palette -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("sarala-theme");
          var ok = ["pro", "classic", "octagon", "machine", "ristretto", "spectrum", "paper"];
          if (t && ok.indexOf(t) !== -1) {
            document.documentElement.setAttribute("data-theme", t);
          }
        } catch (e) {}
      })();
    </script>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
    <script src="../scripts/app.js"></script>
  </body>
</html>
